# Environment variables for VeriGraph backend
# Copy this file to .env and update values as needed

# Deployed URLs:
# Staging: https://verigraph-api-staging.fly.dev
# Production: https://verigraph-api.fly.dev

# API Settings
PORT=8000
HOST=0.0.0.0

# CORS
FRONTEND_URL=http://localhost:5173

# Database
NEON_DB_URL=postgresql://username:password@host/database?sslmode=require

# MLflow Model Registry Settings
# Model name in MLflow (use 'fact-checker-gan' for GAN models)
MODEL_NAME=fact-checker-gan

# Environment identifier (used to route tasks to correct ML server)
# 'Staging' or 'Production'
MODEL_STAGE=Staging
