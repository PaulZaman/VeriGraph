# Environment variables for VeriGraph backend
# Copy this file to .env and update values as needed

# Deployed URLs:
# Staging: https://verigraph-api-staging.fly.dev
# Production: https://verigraph-api.fly.dev

# API Settings
PORT=8000
HOST=0.0.0.0

# CORS
FRONTEND_URL=http://localhost:5173

# Model Configuration
DAGSHUB_REPO=MarcoSrhl/NLP-Fact-checking
MODEL_NAME=fact-checker-bert
MODEL_VERSION=1

# DagHub Authentication (optional for public repos)
# DAGSHUB_USER=your-username
# DAGSHUB_TOKEN=your-token
