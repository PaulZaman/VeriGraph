# Database Connection
NEON_DB_URL=postgresql://username:password@host/database?sslmode=require

# DagHub Authentication
DAGSHUB_USER=MarcoSrhl
DAGSHUB_TOKEN=your_dagshub_token_here
DAGSHUB_REPO=MarcoSrhl/NLP-Fact-checking

# Model Configuration
MODEL_NAME=fact-checker-bert

# Optional: HuggingFace model fallback (if DagHub fails)
# Example: HUGGINGFACE_MODEL=bert-base-uncased
# HUGGINGFACE_MODEL=your-username/your-model

# Worker Configuration
POLL_INTERVAL=5
MAX_RETRIES=3
